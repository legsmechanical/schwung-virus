{
    "id": "osirus",
    "name": "Osirus",
    "abbrev": "OS",
    "version": "0.6.0",
    "description": "Access Virus DSP56300 emulator (Gearmulator)",
    "author": "dsp56300/gearmulator (port: charlesvestal)",
    "ui": "ui.js",
    "dsp": "dsp.so",
    "api_version": 2,
    "assets": {
        "path": "roms",
        "label": "ROMs",
        "extensions": [
            ".mid",
            ".bin",
            ".BIN"
        ],
        "description": "Requires at least one Virus ROM. Virus A needs both .mid files; B or C need one .BIN file. Optional .mid SysEx preset banks can also be added.",
        "hint": "Virus A runs at full DSP quality. B/C run at reduced clock (50% default). Multiple ROMs supported — select in Settings.",
        "hint_url": "https://github.com/charlesvestal/schwung-virus",
        "hint_url_label": "Read more",
        "files": [
            {
                "filename": "virus_a_firmware.mid",
                "label": "Virus A firmware (First_A_28.mid)",
                "size": 514611,
                "required": false
            },
            {
                "filename": "virus_a_presets.mid",
                "label": "Virus A presets (second_A_28.mid)",
                "size": 514611,
                "required": false
            },
            {
                "filename": "virus_b.BIN",
                "label": "Virus B firmware (Access Virus B (am29f040b_4v9).BIN)",
                "size": 524288,
                "required": false
            },
            {
                "filename": "virus_c.BIN",
                "label": "Virus C firmware (Access Virus C (am29f040b_6v6).BIN)",
                "size": 524288,
                "required": false
            }
        ]
    },
    "capabilities": {
        "audio_out": true,
        "audio_in": false,
        "midi_in": true,
        "midi_out": false,
        "default_forward_channel": 1,
        "chainable": true,
        "component_type": "sound_generator"
    },
    "chain_params": [
        {"key": "cutoff", "name": "Cutoff", "type": "int", "min": 0, "max": 127},
        {"key": "filter1_resonance", "name": "Resonance", "type": "int", "min": 0, "max": 127},
        {"key": "filter1_env_amt", "name": "Filt Env Amt", "type": "int", "min": 0, "max": 127},
        {"key": "flt_attack", "name": "Flt Attack", "type": "int", "min": 0, "max": 127},
        {"key": "flt_decay", "name": "Flt Decay", "type": "int", "min": 0, "max": 127},
        {"key": "flt_sustain", "name": "Flt Sustain", "type": "int", "min": 0, "max": 127},
        {"key": "flt_release", "name": "Flt Release", "type": "int", "min": 0, "max": 127},
        {"key": "amp_attack", "name": "Amp Attack", "type": "int", "min": 0, "max": 127},
        {"key": "amp_decay", "name": "Amp Decay", "type": "int", "min": 0, "max": 127},
        {"key": "amp_sustain", "name": "Amp Sustain", "type": "int", "min": 0, "max": 127},
        {"key": "amp_release", "name": "Amp Release", "type": "int", "min": 0, "max": 127},
        {"key": "filter1_mode", "name": "Filter Mode", "type": "int", "min": 0, "max": 7},
        {"key": "osc1_shape", "name": "Osc1 Shape", "type": "int", "min": 0, "max": 127},
        {"key": "osc2_shape", "name": "Osc2 Shape", "type": "int", "min": 0, "max": 127},
